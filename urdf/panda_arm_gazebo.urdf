<?xml version="1.0"?>
<robot name="panda_arm">
  <link name="world"/>
  <joint name="world_fix" type="fixed">
    <parent link="world"/><child link="base"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- Base pedestal -->
  <link name="base">
    <visual><origin xyz="0 0 0.05"/><geometry><cylinder radius="0.09" length="0.1"/></geometry>
      <material name="grey"><color rgba="0.7 0.7 0.7 1"/></material></visual>
    <collision><origin xyz="0 0 0.05"/><geometry><cylinder radius="0.09" length="0.1"/></geometry></collision>
    <inertial><mass value="3.0"/><origin xyz="0 0 0.05"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>

  <!-- Shoulder (rotating base) -->
  <joint name="j1" type="fixed">
    <parent link="base"/><child link="shoulder"/>
    <origin xyz="0 0 0.1"/>
  </joint>
  <link name="shoulder">
    <visual><origin xyz="0 0 0.1"/><geometry><cylinder radius="0.065" length="0.2"/></geometry>
      <material name="white"><color rgba="0.95 0.95 0.95 1"/></material></visual>
    <collision><origin xyz="0 0 0.1"/><geometry><cylinder radius="0.065" length="0.2"/></geometry></collision>
    <inertial><mass value="2.0"/><origin xyz="0 0 0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>

  <!-- Upper arm (tilted forward) -->
  <joint name="j2" type="fixed">
    <parent link="shoulder"/><child link="upper_arm"/>
    <origin xyz="0 0 0.2" rpy="0 0.4 0"/>
  </joint>
  <link name="upper_arm">
    <visual><origin xyz="0 0 0.155"/><geometry><box size="0.055 0.055 0.31"/></geometry>
      <material name="orange"><color rgba="1.0 0.55 0.0 1"/></material></visual>
    <collision><origin xyz="0 0 0.155"/><geometry><box size="0.055 0.055 0.31"/></geometry></collision>
    <inertial><mass value="1.5"/><origin xyz="0 0 0.155"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>

  <!-- Elbow joint piece -->
  <joint name="j3" type="fixed">
    <parent link="upper_arm"/><child link="elbow"/>
    <origin xyz="0 0 0.31" rpy="0 0.5 0"/>
  </joint>
  <link name="elbow">
    <visual><origin xyz="0 0 0.03"/><geometry><sphere radius="0.05"/></geometry>
      <material name="white2"><color rgba="0.95 0.95 0.95 1"/></material></visual>
    <collision><origin xyz="0 0 0.03"/><geometry><sphere radius="0.05"/></geometry></collision>
    <inertial><mass value="0.5"/><origin xyz="0 0 0.03"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
  </link>

  <!-- Forearm (angled down toward table) -->
  <joint name="j4" type="fixed">
    <parent link="elbow"/><child link="forearm"/>
    <origin xyz="0 0 0.06" rpy="0 0.3 0"/>
  </joint>
  <link name="forearm">
    <visual><origin xyz="0 0 0.12"/><geometry><box size="0.045 0.045 0.24"/></geometry>
      <material name="orange2"><color rgba="1.0 0.55 0.0 1"/></material></visual>
    <collision><origin xyz="0 0 0.12"/><geometry><box size="0.045 0.045 0.24"/></geometry></collision>
    <inertial><mass value="1.0"/><origin xyz="0 0 0.12"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/></inertial>
  </link>

  <!-- Wrist -->
  <joint name="j5" type="fixed">
    <parent link="forearm"/><child link="wrist"/>
    <origin xyz="0 0 0.24" rpy="0 -0.7 0"/>
  </joint>
  <link name="wrist">
    <visual><origin xyz="0 0 0.04"/><geometry><cylinder radius="0.03" length="0.08"/></geometry>
      <material name="white3"><color rgba="0.95 0.95 0.95 1"/></material></visual>
    <collision><origin xyz="0 0 0.04"/><geometry><cylinder radius="0.03" length="0.08"/></geometry></collision>
    <inertial><mass value="0.4"/><origin xyz="0 0 0.04"/><inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/></inertial>
  </link>

  <!-- Gripper left finger -->
  <joint name="j_finger_l" type="fixed">
    <parent link="wrist"/><child link="finger_left"/>
    <origin xyz="0 0.02 0.08"/>
  </joint>
  <link name="finger_left">
    <visual><origin xyz="0 0 0.025"/><geometry><box size="0.015 0.01 0.05"/></geometry>
      <material name="dark"><color rgba="0.3 0.3 0.3 1"/></material></visual>
    <collision><origin xyz="0 0 0.025"/><geometry><box size="0.015 0.01 0.05"/></geometry></collision>
    <inertial><mass value="0.1"/><origin xyz="0 0 0.025"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <!-- Gripper right finger -->
  <joint name="j_finger_r" type="fixed">
    <parent link="wrist"/><child link="finger_right"/>
    <origin xyz="0 -0.02 0.08"/>
  </joint>
  <link name="finger_right">
    <visual><origin xyz="0 0 0.025"/><geometry><box size="0.015 0.01 0.05"/></geometry>
      <material name="dark2"><color rgba="0.3 0.3 0.3 1"/></material></visual>
    <collision><origin xyz="0 0 0.025"/><geometry><box size="0.015 0.01 0.05"/></geometry></collision>
    <inertial><mass value="0.1"/><origin xyz="0 0 0.025"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
</robot>
